# Anthropic API key — required
# Get yours at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxx

# Path to the tutor system prompt file
# Default: ../templates/tutor-prompt.md
SYSTEM_PROMPT_PATH=../templates/tutor-prompt.md

# Model to use
# Default: claude-sonnet-4-6
# Options: claude-sonnet-4-6, claude-opus-4-6
MODEL=claude-sonnet-4-6

# Extended thinking — gives the model a scratchpad to check its own
# behavior before responding.  Improves one-question-at-a-time compliance,
# tone calibration, and diagnostic accuracy.  Enabled by default.
# Set to "false" to disable.
EXTENDED_THINKING=true
